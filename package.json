{
  "name": "plato-chat",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:web": "npx expo export --platform web",
    "serve:web": "npx serve dist",
    "prebuild:clean": "npx expo prebuild --clean",
    "compile": "tsc --noEmit -p . --pretty",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "align-deps": "npx expo install --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:maestro": "maestro test -e MAESTRO_APP_ID=com.platochat .maestro/flows",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "build:ios:sim": "NODE_ENV=development eas build --profile development --platform ios --local",
    "build:ios:dev": "NODE_ENV=development eas build --profile development:device --platform ios --local",
    "build:ios:simpreview": "NODE_ENV=development eas build --profile preview --platform ios --local",
    "build:ios:devpreview": "NODE_ENV=development eas build --profile preview:device --platform ios --local",
    "build:ios:prod": "NODE_ENV=production eas build --profile production --platform ios --local",
    "build:android:sim": "NODE_ENV=development eas build --profile development --platform android --local",
    "build:android:dev": "NODE_ENV=development eas build --profile development:device --platform android --local",
    "build:android:preview": "NODE_ENV=development eas build --profile preview --platform android --local",
    "build:android:prod": "NODE_ENV=production eas build --profile production --platform android --local"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.23",
    "@clerk/expo": "^3.0.0",
    "@clerk/react": "^6.5.0",
    "@convex-dev/agent": "^0.1.15",
    "@convex-dev/rate-limiter": "^0.2.11",
    "@expo-google-fonts/space-grotesk": "^0.4.0",
    "@expo/metro-runtime": "~55.0.10",
    "@expo/vector-icons": "^15.1.1",
    "@openrouter/ai-sdk-provider": "0.7.1",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-navigation/drawer": "7.9.9",
    "@react-navigation/native": "7.2.2",
    "@react-navigation/native-stack": "7.14.12",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "1.8.1",
    "apisauce": "3.1.1",
    "convex": "^1.25.2",
    "date-fns": "^4.1.0",
    "expo": "~55.0.20",
    "expo-auth-session": "~55.0.15",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "^55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.32",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-system-ui": "~55.0.16",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "i18next": "^23.14.0",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.0.1",
    "react-native": "0.83.6",
    "react-native-drawer-layout": "^4.0.1",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-remark": "^1.0.5",
    "react-native-renderer": "^15.5.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-jest": "^29.2.1",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-reactotron": "^0.1.2",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.0.0",
    "reactotron-core-client": "^2.9.4",
    "reactotron-react-js": "^3.3.11",
    "reactotron-react-native": "^5.0.5",
    "reactotron-react-native-mmkv": "^0.2.6",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list"
      ]
    }
  }
}
